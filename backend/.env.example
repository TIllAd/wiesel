# LTI 1.1 Credentials (mock for now, will be provided by RRZE/StudOn)
LTI_CONSUMER_KEY=test_consumer_key_mock
LTI_CONSUMER_SECRET=test_consumer_secret_mock

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-you...here
ANTHROPIC_MODEL=claude-haiku-4-5

# Cost estimation for analytics, USD per 1M tokens
# Adjust when Anthropic pricing changes. These numbers only affect reporting,
# not billing.
USD_PER_EUR=1.08
LLM_INPUT_USD_PER_MTOK=1.00
LLM_OUTPUT_USD_PER_MTOK=5.00
LLM_CACHE_WRITE_USD_PER_MTOK=1.25 #currently 5 min window
LLM_CACHE_READ_USD_PER_MTOK=0.10

# JWT Secret for session tokens
JWT_SECRET=wiesel_jwt_secret_dev

# Database (absolute path for Docker)
DATABASE_URL=sqlite:////app/wiesel.db

# FastAPI
ENVIRONMENT=development

# Analysis & Reporting
WIESEL_API_BASE=http://localhost:8001
REPORT_EMAIL=deine@email.de
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dein@gmail.com
SMTP_PASS=dein-app-passwort
