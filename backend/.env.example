# LTI 1.1 Credentials (mock for now, will be provided by RRZE/StudOn)
LTI_CONSUMER_KEY=test_consumer_key_mock
LTI_CONSUMER_SECRET=test_consumer_secret_mock

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-you...here
ANTHROPIC_MODEL=claude-haiku-4-5

# Cost estimation for analytics, USD per 1M tokens
# Adjust when Anthropic pricing changes. These numbers only affect reporting,
# not billing.
USD_PER_EUR=1.08
LLM_INPUT_USD_PER_MTOK=1.00
LLM_OUTPUT_USD_PER_MTOK=5.00
LLM_CACHE_WRITE_USD_PER_MTOK=1.25 #currently 5 min window
LLM_CACHE_READ_USD_PER_MTOK=0.10

# JWT Secret for session tokens
JWT_SECRET=wiesel_jwt_secret_dev

CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# Database (absolute path for Docker)
DATABASE_URL=sqlite:////app/wiesel.db

# FastAPI
# In "production" verweigert die App den Start, wenn Secrets fehlen oder auf
# Dev-Defaults stehen (JWT_SECRET, ANTHROPIC_API_KEY, ADMIN_API_KEY, LTI-Secret).
ENVIRONMENT=development

# ── Security / Ops (P0, Juli 2026) ──────────────────────────────────────────
# WICHTIG: MOCK_LTI_MODE=true überspringt die OAuth-Signaturprüfung komplett.
# Erst auf false stellen, nachdem ein echter StudOn-Launch gegen die reparierte
# Signaturprüfung getestet wurde (Fix-Plan Phase 1, Schritt 1 → 2).
MOCK_LTI_MODE=true

# Admin-Key für /api/logs/daily, /api/reports/*, /api/usage/*, /api/analytics/*,
# /api/session/*  (Header: X-Admin-Key). Ohne Key sind diese Endpoints gesperrt (503).
# Wird weiterhin gebraucht für Zugriffe OHNE Cloudflare Access (Scripts, Tests, Fable).
ADMIN_API_KEY=

# Cloudflare Access als zweiter Auth-Weg (Team-Login statt Key):
# Team-Domain z. B. "wiso-team" (wird zu wiso-team.cloudflareaccess.com) und das
# Audience-Tag der Access-Application (Zero Trust → Access → Applications → AUD).
# Beide gesetzt → gültiger Cf-Access-Jwt-Assertion-Header zählt als Admin-Auth.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# CORS: erlaubte Origins, kommagetrennt.
ALLOWED_ORIGINS=https://wiesel.chatbot-wiso.de

# Kosten-Kill-Switch: bei Erreichen pausieren LLM-Calls bis Mitternacht (0 = aus).
DAILY_BUDGET_EUR=15

# Rate-Limits
RATE_LIMIT_CHAT_PER_MIN_SESSION=10
RATE_LIMIT_CHAT_PER_MIN_IP=30
RATE_LIMIT_DEBUG_SESSIONS_PER_DAY_IP=20

# LLM-Antwortlänge (Kürze kommt aus dem Prompt; das hier ist die Notbremse)
LLM_MAX_TOKENS=700

# Session-Token-Lebensdauer in Stunden
JWT_TTL_HOURS=2

# Analysis & Reporting
WIESEL_API_BASE=http://localhost:8001
REPORT_EMAIL=deine@email.de
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dein@gmail.com
SMTP_PASS=dein-app-passwort
